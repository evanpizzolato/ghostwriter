{
  "name": "ghostwriter",
  "version": "0.42.2",
  "description": "Privacy-focused notes that stay hidden from screenshots and screen shares",
  "main": "main.js",
  "scripts": {
    "start": "electronmon main.js",
    "dist": "electron-builder",
    "dist-mac": "electron-builder --mac",
    "build": "electron-builder --publish=never",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "37.4.0",
    "electron-builder": "^26.5.0",
    "electronmon": "2.0.4"
  },
  "build": {
    "appId": "com.evanpizzolato.ghostwriter",
    "productName": "Ghostwriter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "build/**/*",
      "package.json",
      "!**/*.md",
      "!**/.DS_Store",
      "!sign-*.sh",
      "!create_temp_icon.sh",
      "!temp_icon.svg",
      "!docs/**",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,.npmignore,.travis.yml}",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": "Evan Pizzolato (463BF86Y8P)",
      "notarize": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Ghostwriter ${version}",
      "icon": "build/icon.icns",
      "background": "build/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 96,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "artifactName": "Ghostwriter.dmg"
    },
    "publish": {
      "provider": "github",
      "owner": "evanpizzolato",
      "repo": "ghostwriter"
    }
  },
  "author": "Evan Pizzolato",
  "license": "GPL-3.0",
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
